# ────────────────────────────────────────────────────────────────
# Production Environment Variables — Backend
# Copy this file to .env and fill in actual values
# ────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_STRONG_PASSWORD@localhost:5432/bhagwan_portfolio?schema=public"

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://bhagwansingh.com

# ── Authentication ────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── AWS S3 (Optional — for cloud file storage) ───────────────
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Redis (Optional — for API response caching) ──────────────
# REDIS_URL=redis://localhost:6379

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
