{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "noEmitOnError": false
  },
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts", "prisma.config.ts", "setup-admin.ts"]
}